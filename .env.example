# Copiá este archivo a .env.local y completá los valores reales.
# .env.local está en .gitignore — nunca se commitea.

# ---------- Supabase (cliente público) ----------
# Dashboard → Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ---------- Postgres (Prisma) ----------
# Dashboard → Project Settings → Database → Connection string
# DATABASE_URL: transaction pooler (puerto 6543) — usado por la app en runtime
# DIRECT_URL:   direct connection (puerto 5432) — usado por prisma migrate
DATABASE_URL=postgresql://postgres.REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here 